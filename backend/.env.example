# OpenAI
OPENAI_API_KEY=

# Database (SQLite default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./accessbank.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/accessbank

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPERVISOR_CHAT_ID=

# Gmail API (OAuth2) — choose Gmail OR Microsoft, not both required
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# Microsoft Graph API (alternative to Gmail)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_SENDER_EMAIL=

# Escalation recipient
ESCALATION_EMAIL=support@accessbank.az

# App settings
APP_ENV=development
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=20

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Optional: skip email in dev when credentials missing
SKIP_EMAIL=false
